[
  {
    "openapi": "3.1.0",
    "info": { "title": "Billing API", "version": "3.2.0" },
    "paths": {
      "/customers/{id}": {
        "get": {
          "operationId": "getCustomer",
          "responses": {
            "200": { "description": "ok", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } } },
            "default": { "description": "error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
          }
        }
      },
      "/invoices": {
        "post": {
          "operationId": "createInvoice",
          "requestBody": {
            "content": { "application/json": { "schema": {
              "type": "object",
              "properties": {
                "total": { "$ref": "#/components/schemas/Money" },
                "billTo": { "$ref": "#/components/schemas/User" }
              }
            } } }
          },
          "responses": { "201": { "description": "created" } }
        }
      }
    },
    "components": {
      "schemas": {
        "Money": { "type": "object", "properties": { "amount": { "type": "string" }, "currency": { "type": "string" } } },
        "Error": { "type": "object", "properties": { "code": { "type": "string" }, "message": { "type": "string" } } }
      }
    }
  },
  {
    "openapi": "3.1.0",
    "info": { "title": "CRM API", "version": "1.4.0" },
    "paths": {
      "/people/{id}": {
        "get": {
          "operationId": "getPerson",
          "responses": {
            "200": { "description": "ok", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } } }
          }
        }
      }
    },
    "components": {
      "schemas": {
        "Customer": {
          "type": "object",
          "description": "CRM's own idea of a user — a drift variant of the library User model.",
          "required": ["id", "email"],
          "properties": {
            "id": { "type": "string" },
            "email": { "type": "string" },
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "status": { "type": "string", "enum": ["lead", "active", "churned"] }
          }
        }
      }
    }
  }
]
